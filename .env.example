# Chave da API do Google Gemini (obrigatória)
CHAVE_API_GOOGLE=

# Banco de dados — opção 1: URL completa (tem prioridade sobre as variáveis abaixo)
# Local:  postgresql://postgres:senha123@localhost:5432/rag_db
# Azure:  postgresql://USUARIO:SENHA@SEUSERVIDOR.postgres.database.azure.com:5432/rag_db?sslmode=require
# DATABASE_URL=

# Banco de dados — opção 2: variáveis separadas (padrões = ambiente local/Docker)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rag_db
# DB_USER=postgres
# DB_PASSWORD=senha123
# DB_SSLMODE=prefer        # no Azure use: require

# Opcionais
# EMBEDDING_MODEL=gemini-embedding-001
# LLM_MODEL=gemini-2.5-flash
# LLM_TEMPERATURE=0.4
# RAG_TOP_K=5
